{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "unicorn", "typescript", "oxc", "promise"],
  "categories": {
    "correctness": "deny",
    "suspicious": "deny",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn",
    "nursery": "warn"
  },
  "rules": {
    "capitalized-comments": [
      "warn",
      "always",
      {
        "ignorePattern": "v8",
        "ignoreConsecutiveComments": true
      }
    ],
    "func-style": [
      "error",
      "declaration",
      {
        "allowArrowFunctions": true
      }
    ],
    "id-length": "allow",
    "no-inline-comments": "allow",
    "no-implicit-coercion": ["error", { "allow": ["!!"] }],
    "switch-case-braces": ["error", "avoid"],
    "no-ternary": "allow",
    "no-continue": "allow",
    "no-shadow": "allow",
    "array-type": ["allow", { "default": "array-simple" }],
    "no-duplicate-imports": ["error", { "allowSeparateTypeImports": true }],
    "consistent-type-imports": "error",
    "no-nested-ternary": "allow",
    "unicorn/no-nested-ternary": "allow",
    "no-negated-condition": "allow",
    "no-magic-numbers": [
      "warn",
      {
        // 6 Rows in the play grid
        "ignore": [-1, 0, 1, 2, 3, 4, 5, 6]
      }
    ],
    "consistent-type-definitions": ["error", "type"],
    "sort-keys": "allow",
    "curly": "allow",
    "sort-imports": "allow", // Handled by fmt
    "filename-case": "error",
    "no-confusing-void-expression": [
      "error",
      {
        "ignoreArrowShorthand": true
      }
    ]
  },
  "overrides": [
    {
      "files": ["**/*.tsx", "src/context/*Context.ts"],
      "plugins": ["react"],
      "rules": {
        "filename-case": [
          "error",
          {
            "cases": {
              "pascalCase": true
            },
            "ignore": "^main.tsx$"
          }
        ],
        "prefer-readonly-parameter-types": [
          "warn",
          {
            "allow": [
              { "from": "package", "name": "ReactNode", "package": "react" }
            ]
          }
        ],
        "react-in-jsx-scope": "allow",
        "jsx-max-depth": [
          "warn",
          {
            "max": 4
          }
        ],
        "max-lines-per-function": [
          "warn",
          {
            "max": 100
          }
        ]
      }
    },
    {
      "files": ["src/test-setup.ts", "**/*.test-utils.ts*", "**/*.test.ts*"],
      "plugins": ["vitest"],
      "rules": {
        "no-await-in-loop": "allow",
        "max-lines-per-function": "allow",
        "prefer-called-once": "error",
        "prefer-called-times": "allow",
        "prefer-readonly-parameter-types": "allow",
        "prefer-to-be-truthy": "allow",
        "prefer-to-be-falsy": "allow",
        "prefer-strict-boolean-matchers": "error",
        "no-empty-interface": "allow",
        "consistent-type-definitions": "allow",
        "max-statements": [
          "warn",
          {
            "max": 15
          }
        ],
        "max-lines": [
          "warn",
          {
            "max": 500
          }
        ]
      },
      "env": {
        "vitest": true
      }
    }
  ],
  "options": {
    "typeAware": true
  },
  "settings": {
    "jsx-a11y": {
      "components": {},
      "attributes": {}
    },
    "react": {
      "formComponents": [],
      "linkComponents": [],
      "componentWrapperFunctions": []
    },
    "jsdoc": {
      "ignorePrivate": false,
      "ignoreInternal": false,
      "ignoreReplacesDocs": true,
      "overrideReplacesDocs": true,
      "augmentsExtendsReplacesDocs": false,
      "implementsReplacesDocs": false,
      "exemptDestructuredRootsFromChecks": false,
      "tagNamePreference": {}
    }
  },
  "env": {
    "browser": true,
    "builtin": true
  },
  "globals": {},
  "ignorePatterns": []
}
